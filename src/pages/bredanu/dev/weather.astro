---
import Layout from '../../../layouts/Layout.astro'
import { Frame } from '../../../components/bredanu/Frame'
import { Ticker } from '../../../components/bredanu/Ticker'
import { WeatherSlide } from '../../../components/bredanu/WeatherSlide'
---

<Layout title="Dev - BredaNu Weather">
  <div class="relative h-[1080px] w-[1920px]">
    <Frame client:only="react">
      <WeatherSlide
        client:only="react"
        content={{
          type: 'weather',
          duration: 15000,
          title: 'Weerbericht',
          location: 'Breda',
          days: [
            { date: 'vandaag',          day_short: 'vandaag', temp_min:  3, temp_max:  8, weather_id: 500, description: 'Lichte regen', icon: '10d', wind_direction: 'ZW',  wind_beaufort: 4 },
            { date: 'donderdag 26 jun', day_short: 'do',      temp_min:  5, temp_max: 12, weather_id: 803, description: 'Bewolkt',      icon: '04d', wind_direction: 'W',   wind_beaufort: 3 },
            { date: 'vrijdag 27 jun',   day_short: 'vr',      temp_min:  8, temp_max: 16, weather_id: 802, description: 'Half bewolkt', icon: '03d', wind_direction: 'WZW', wind_beaufort: 4 },
            { date: 'zaterdag 28 jun',  day_short: 'za',      temp_min: 11, temp_max: 21, weather_id: 800, description: 'Zonnig',       icon: '01d', wind_direction: 'Z',   wind_beaufort: 2 },
            { date: 'zondag 29 jun',    day_short: 'zo',      temp_min: 14, temp_max: 26, weather_id: 801, description: 'Zonnig',       icon: '02d', wind_direction: 'ZO',  wind_beaufort: 3 },
          ],
        }}
      >
        <Ticker
          client:only="react"
          items={[{ message: 'Dit is een ticker bericht' }]}
          currentIndex={0}
        />
      </WeatherSlide>
    </Frame>
  </div>
</Layout>
